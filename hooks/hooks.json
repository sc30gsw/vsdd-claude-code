{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_DIR}/scripts/hooks/vcsdd-gate-check.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_DIR}/scripts/hooks/vcsdd-coherence-refresh.js\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_DIR}/scripts/hooks/vcsdd-auto-commit.js\""
          }
        ]
      }
    ]
  }
}
