{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vcsdd.finding.v1",
  "title": "VCSDD Adversary Finding",
  "type": "object",
  "required": ["findingId", "dimension", "category", "severity", "description", "evidence", "routeToPhase"],
  "additionalProperties": false,
  "properties": {
    "findingId": { "type": "string", "pattern": "^FIND-\\d{3,}$" },
    "dimension": { "type": "string", "enum": ["spec_fidelity", "edge_case_coverage", "implementation_correctness", "structural_integrity", "verification_readiness"] },
    "category": {
      "type": "string",
      "enum": [
        "spec_ambiguity",
        "spec_gap",
        "requirement_mismatch",
        "missing_edge_case",
        "test_coverage",
        "test_quality",
        "implementation_bug",
        "error_handling",
        "security_surface",
        "code_structure",
        "naming",
        "duplication",
        "proof_gap",
        "invariant_violation",
        "purity_boundary",
        "verification_tool_mismatch"
      ]
    },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "description": { "type": "string", "minLength": 20 },
    "evidence": {
      "type": "object",
      "required": ["filePath", "lineRange"],
      "additionalProperties": false,
      "properties": {
        "filePath": { "type": "string", "minLength": 1 },
        "lineRange": { "type": "string", "pattern": "^\\d+-\\d+$" },
        "snippet": { "type": "string" },
        "testName": { "type": "string" }
      }
    },
    "routeToPhase": { "type": "string", "enum": ["1a", "1b", "2a", "2b", "2c", "5"] },
    "beadId": { "type": "string" },
    "resolution": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["open", "fixed", "wont-fix", "duplicate"] },
        "fixedInSprint": { "type": "integer", "minimum": 1 },
        "fixedInPhase": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
