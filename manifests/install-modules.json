{
  "modules": [
    {
      "id": "vcsdd-rules",
      "kind": "rules",
      "description": "VCSDD principles, gate enforcement, and anti-slop bias rules",
      "paths": ["rules/common/"],
      "targets": ["claude"],
      "dependencies": [],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-runtime",
      "kind": "runtime",
      "description": "Core VCSDD state and traceability libraries required by the slash commands",
      "paths": ["scripts/lib/"],
      "targets": ["claude"],
      "dependencies": [],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-schemas",
      "kind": "schemas",
      "description": "JSON schemas for VCSDD state, grading, findings, contracts, and beads",
      "paths": ["schemas/"],
      "targets": ["claude"],
      "dependencies": [],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-manifests",
      "kind": "manifests",
      "description": "Install and language profile manifests used by the installer and verifier",
      "paths": ["manifests/"],
      "targets": ["claude"],
      "dependencies": [],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-docs",
      "kind": "docs",
      "description": "Methodology and orchestration reference documents shipped with the plugin",
      "paths": ["CLAUDE.md", "VCSDD.md", "AGENTS.md"],
      "targets": ["claude"],
      "dependencies": [],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-contexts",
      "kind": "contexts",
      "description": "Session context files that summarize the active VCSDD pipeline",
      "paths": ["contexts/"],
      "targets": ["claude"],
      "dependencies": ["vcsdd-docs"],
      "defaultInstall": false,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-commands",
      "kind": "commands",
      "description": "Core VCSDD slash commands for pipeline control (coherence commands ship with vcsdd-coherence)",
      "paths": [
        "commands/vcsdd-adversary.md",
        "commands/vcsdd-commit.md",
        "commands/vcsdd-contract-review.md",
        "commands/vcsdd-converge.md",
        "commands/vcsdd-escalate.md",
        "commands/vcsdd-feedback.md",
        "commands/vcsdd-harden.md",
        "commands/vcsdd-impl.md",
        "commands/vcsdd-init.md",
        "commands/vcsdd-spec-review.md",
        "commands/vcsdd-spec.md",
        "commands/vcsdd-status.md",
        "commands/vcsdd-tdd.md",
        "commands/vcsdd-trace.md"
      ],
      "targets": ["claude"],
      "dependencies": ["vcsdd-rules", "vcsdd-runtime", "vcsdd-schemas"],
      "defaultInstall": true,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-agents",
      "kind": "agents",
      "description": "4 VCSDD agents: orchestrator, builder, adversary (opus), verifier",
      "paths": [
        "agents/vcsdd-orchestrator.md",
        "agents/vcsdd-builder.md",
        "agents/vcsdd-adversary.md",
        "agents/vcsdd-verifier.md"
      ],
      "targets": ["claude"],
      "dependencies": ["vcsdd-rules", "vcsdd-commands"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "vcsdd-skills",
      "kind": "skills",
      "description": "VCSDD skill bundles for slash-command workflows plus the core methodology skills (language and coherence skills are separate modules)",
      "paths": [
        "skills/vcsdd-adversary/",
        "skills/vcsdd-commit/",
        "skills/vcsdd-contract-review/",
        "skills/vcsdd-converge/",
        "skills/vcsdd-escalate/",
        "skills/vcsdd-feedback/",
        "skills/vcsdd-harden/",
        "skills/vcsdd-impl/",
        "skills/vcsdd-init/",
        "skills/vcsdd-spec/",
        "skills/vcsdd-spec-review/",
        "skills/vcsdd-spec-crystallization/",
        "skills/vcsdd-status/",
        "skills/vcsdd-sprint-contracts/",
        "skills/vcsdd-tdd/",
        "skills/vcsdd-trace/",
        "skills/vcsdd-adversarial-refinement/",
        "skills/vcsdd-grading-criteria/",
        "skills/vcsdd-feedback-routing/",
        "skills/vcsdd-convergence-detection/",
        "skills/vcsdd-formal-hardening/",
        "skills/vcsdd-verification-architecture/",
        "skills/vcsdd-traceability/",
        "skills/vcsdd-git-integration/"
      ],
      "targets": ["claude"],
      "dependencies": ["vcsdd-rules"],
      "defaultInstall": true,
      "cost": "medium",
      "stability": "stable"
    },
    {
      "id": "vcsdd-hooks",
      "kind": "hooks",
      "description": "Gate enforcement, session persistence, and auto-commit hooks",
      "paths": ["hooks/hooks.json", "scripts/"],
      "targets": ["claude"],
      "dependencies": ["vcsdd-rules"],
      "defaultInstall": false,
      "cost": "medium",
      "stability": "beta"
    },
    {
      "id": "vcsdd-language-rust",
      "kind": "skills",
      "description": "Rust-specific VCSDD skill: Kani, proptest, cargo-fuzz, cargo-mutants",
      "paths": ["skills/vcsdd-language-rust/"],
      "targets": ["claude"],
      "dependencies": ["vcsdd-skills"],
      "defaultInstall": false,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-language-python",
      "kind": "skills",
      "description": "Python-specific VCSDD skill: hypothesis, mutmut",
      "paths": ["skills/vcsdd-language-python/"],
      "targets": ["claude"],
      "dependencies": ["vcsdd-skills"],
      "defaultInstall": false,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-language-typescript",
      "kind": "skills",
      "description": "TypeScript-specific VCSDD skill: fast-check, stryker",
      "paths": ["skills/vcsdd-language-typescript/"],
      "targets": ["claude"],
      "dependencies": ["vcsdd-skills"],
      "defaultInstall": false,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-language-go-profile",
      "kind": "manifests",
      "description": "Go verification tool profile (manifest-backed; no dedicated skill bundle)",
      "paths": ["manifests/language-profiles.json"],
      "targets": ["claude"],
      "dependencies": ["vcsdd-skills"],
      "defaultInstall": false,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-language-cpp-profile",
      "kind": "manifests",
      "description": "C/C++ verification tool profile (manifest-backed; no dedicated skill bundle)",
      "paths": ["manifests/language-profiles.json"],
      "targets": ["claude"],
      "dependencies": ["vcsdd-skills"],
      "defaultInstall": false,
      "cost": "light",
      "stability": "stable"
    },
    {
      "id": "vcsdd-coherence",
      "kind": "skills",
      "description": "Coherence Engine: CEG dependency graph, Noisy-OR confidence scoring, BFS impact propagation, and DFS cycle detection natively implemented in Node.js",
      "paths": [
        "scripts/lib/vcsdd-coherence.js",
        "schemas/vcsdd-coherence.schema.json",
        "skills/vcsdd-coherence-scan/",
        "skills/vcsdd-coherence-impact/",
        "skills/vcsdd-coherence-validate/",
        "commands/vcsdd-coherence-scan.md",
        "commands/vcsdd-coherence-impact.md",
        "commands/vcsdd-coherence-validate.md"
      ],
      "targets": ["claude"],
      "dependencies": ["vcsdd-runtime", "vcsdd-schemas", "vcsdd-skills"],
      "defaultInstall": false,
      "cost": "medium",
      "stability": "beta"
    }
  ]
}
